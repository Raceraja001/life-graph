# Environment Configuration
# Copy to .env and customize

# Database
LIFE_GRAPH_DATABASE_URL=postgresql+asyncpg://life_graph:life_graph@localhost:5432/life_graph
LIFE_GRAPH_DATABASE_URL_SYNC=postgresql://life_graph:life_graph@localhost:5432/life_graph

# LLM (via LiteLLM)
LIFE_GRAPH_LLM_MODEL_CHEAP=gemini/gemini-2.0-flash
LIFE_GRAPH_LLM_MODEL_EXPENSIVE=gemini/gemini-2.5-pro
LIFE_GRAPH_LLM_DAILY_BUDGET_USD=1.0

# Embeddings (local, no API cost)
LIFE_GRAPH_EMBEDDING_MODEL=all-mpnet-base-v2
LIFE_GRAPH_EMBEDDING_DIMENSION=768

# MinIO
LIFE_GRAPH_MINIO_ENDPOINT=localhost:9000
LIFE_GRAPH_MINIO_ACCESS_KEY=minioadmin
LIFE_GRAPH_MINIO_SECRET_KEY=minioadmin

# Multi-Modal (Voice)
WHISPER_MODEL=small
LIFE_GRAPH_WHISPER_MODEL=small

# API Authentication (leave empty to disable auth in dev mode)
LIFE_GRAPH_API_KEY=

# Debug
LIFE_GRAPH_DEBUG=false
LIFE_GRAPH_LOG_LEVEL=INFO

# OS Kernel
LIFE_GRAPH_KERNEL_MAX_CONCURRENT_TASKS=5
LIFE_GRAPH_KERNEL_DEFAULT_TIMEOUT=300
LIFE_GRAPH_KERNEL_DEFAULT_MAX_RETRIES=2
LIFE_GRAPH_KERNEL_TASK_CLEANUP_DAYS=30
LIFE_GRAPH_KERNEL_ENABLE_SCHEDULER=true
LIFE_GRAPH_KERNEL_MAX_CONSECUTIVE_FAILURES=3

# ── Personal AI ──────────────────────────────────────
LIFE_GRAPH_ADVISOR_MODELS=openrouter/openai/gpt-4o-mini,openrouter/deepseek/deepseek-chat,openrouter/meta-llama/llama-3.1-8b-instruct
LIFE_GRAPH_ADVISOR_TIMEOUT_SECONDS=10
LIFE_GRAPH_ADVISOR_MAX_COST_PER_QUERY=0.01
LIFE_GRAPH_RESEARCH_STALE_DAYS=30
LIFE_GRAPH_RESEARCH_MAX_PER_RUN=5
LIFE_GRAPH_RESEARCH_MONTHLY_BUDGET_USD=0.60
LIFE_GRAPH_RESEARCH_CONFIDENCE_THRESHOLD=0.7

# ── The Lifeline (backups, docker-compose.production.yml `backup` service) ──
BACKUP_RETENTION_DAYS=30
# Off-site encrypted backups via restic (optional; see docs/OPERATIONS.md)
RESTIC_REPOSITORY=
RESTIC_PASSWORD=

# ── Capture Spine: Interview + Daily Brief ───────────
LIFE_GRAPH_INTERVIEW_MAX_QUESTIONS_PER_DAY=3
LIFE_GRAPH_INTERVIEW_QUESTION_TTL_DAYS=7
LIFE_GRAPH_BRIEF_HOUR_UTC=2

# ── Agent Drivers ─────────────────────────────────────
LIFE_GRAPH_DRIVER_CLAUDE_CODE_BIN=claude
