# Environment Configuration
# Copy to .env and customize

# Database
LIFE_GRAPH_DATABASE_URL=postgresql+asyncpg://life_graph:life_graph@localhost:5432/life_graph
LIFE_GRAPH_DATABASE_URL_SYNC=postgresql://life_graph:life_graph@localhost:5432/life_graph

# LLM (via LiteLLM)
LIFE_GRAPH_LLM_MODEL_CHEAP=gemini/gemini-2.0-flash
LIFE_GRAPH_LLM_MODEL_EXPENSIVE=gemini/gemini-2.5-pro
LIFE_GRAPH_LLM_DAILY_BUDGET_USD=1.0

# Embeddings (local, no API cost)
LIFE_GRAPH_EMBEDDING_MODEL=all-mpnet-base-v2
LIFE_GRAPH_EMBEDDING_DIMENSION=768

# MinIO
LIFE_GRAPH_MINIO_ENDPOINT=localhost:9000
LIFE_GRAPH_MINIO_ACCESS_KEY=minioadmin
LIFE_GRAPH_MINIO_SECRET_KEY=minioadmin

# Multi-Modal (Voice)
WHISPER_MODEL=small
LIFE_GRAPH_WHISPER_MODEL=small

# Debug
LIFE_GRAPH_DEBUG=false
LIFE_GRAPH_LOG_LEVEL=INFO
